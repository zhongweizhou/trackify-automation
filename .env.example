# Task 13 optional MiniMax Anthropic-compatible fallback.
# Keep disabled until a local, untracked .env contains a real API key.
AI_TRIAGE_LLM_ENABLED=0
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=replace_with_local_secret
ANTHROPIC_MODEL=MiniMax-M3

# python.org macOS builds may lack their expected CA file. Keep TLS verification
# enabled and uncomment this only when the live probe reports a TLS failure.
# SSL_CERT_FILE=/etc/ssl/cert.pem
